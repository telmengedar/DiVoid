<?xml version="1.0" encoding="utf-8"?>
<!--
  nuget.config — private feed configuration for container builds.

  The Pooshit packages (Pooshit.AspNetCore.Services, Pooshit.Ocelot,
  Pooshit.Json, Pooshit.Http) are distributed as .nupkg files in a
  local-filesystem feed rather than a remote NuGet server.

  Before running `docker build`, copy the required packages into the
  `packages/` directory at the repo root. A helper script is provided:

      scripts/copy-packages.sh      # Linux/macOS/WSL
      scripts/copy-packages.ps1     # Windows PowerShell

  The `packages/` directory is excluded from git (see .gitignore) but
  intentionally NOT excluded from the Docker build context (see
  .dockerignore), so the SDK stage can restore from it.

  On developer machines the packages can be sourced from:
    - The local file feed:     %APPDATA%/NuGet local config (file:// path)
    - The global package cache: %USERPROFILE%/.nuget/packages/<pkg>/<ver>/*.nupkg

  The script defaults to the global package cache location.
-->
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
    <add key="local-private" value="packages/" />
  </packageSources>
</configuration>
