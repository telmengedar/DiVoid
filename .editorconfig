root = true

[*.cs]
# Fix fluent/chained call alignment
csharp_preserve_static_implicitly_typed_out_parameters = true
csharp_indent_case_contents = true
csharp_indent_switch_labels = true
# The nuclear option for K&R:
csharp_new_line_before_open_brace = accessors, anonymous_methods, anonymous_types, control_blocks, events, indexers, lambdas, local_functions, methods, object_collection_array_initializers, properties, types
csharp_new_line_before_else = false
csharp_new_line_before_catch = false
csharp_new_line_before_finally = false
# Specifically for Fluent APIs/Chained calls
csharp_new_line_before_open_brace = all
csharp_indent_labels = one_less_than_current
# Add these specifically to override the 'New Line' engine
csharp_style_expression_bodied_methods = when_on_single_line:suggestion
csharp_style_expression_bodied_constructors = when_on_single_line:suggestion
# This is the "nuclear" fix for the diagnostic engine
dotnet_style_formatting_newline_before_open_brace = none

# Force 4-space indentation for all C# files
indent_style = space
indent_size = 4

dotnet_diagnostic.IDE0055.severity = warning