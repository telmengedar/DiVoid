{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:3000",
      "https://divoid.mamgo.io"
    ]
  },
  "Database": {
    "Type": "Sqlite",
    "Source": "DiVoid.db3"
  },
  "Auth": {
    "Enabled": true
  },
  "Keycloak": {
    "Authority": "https://auth.mamgo.io/realms/master",
    "Audience": "DiVoid",
    "RequireHttpsMetadata": false,
    "UserIdClaimName": "userId"
  }
}
