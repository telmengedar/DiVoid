# DiVoid Frontend — environment variables
# Copy this file to .env.local and fill in the values.
# All VITE_* vars are baked into the bundle at build time.

# Keycloak OIDC authority (issuer URL).
# Default: DiVoid production Keycloak realm.
VITE_KEYCLOAK_AUTHORITY=https://auth.mamgo.io/realms/master

# Keycloak client ID for the DiVoid SPA (public client, PKCE S256).
VITE_KEYCLOAK_CLIENT_ID=DiVoid

# DiVoid backend API base URL (no trailing slash).
# Dev: http://localhost:5007/api
# Prod: https://divoid.mamgo.io/api
VITE_API_BASE_URL=http://localhost:5007/api

# OIDC redirect URI after login (must match Keycloak client config).
# Default: <origin>/callback — set explicitly if your dev port differs from 3000.
VITE_OIDC_REDIRECT_URI=http://localhost:3000/callback

# OIDC redirect URI after logout (must match Keycloak client config).
VITE_OIDC_POST_LOGOUT_REDIRECT_URI=http://localhost:3000/logout
